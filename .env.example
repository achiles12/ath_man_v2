# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Credentials used by both docker-compose and the backend application.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=athlete_manager

# ── Backend ───────────────────────────────────────────────────────────────────
# Used by the FastAPI app to connect to the database.
# Inside Docker: hostname is the service name (athlete_db).
# Outside Docker (local pytest): use localhost and the mapped port (20301).
DATABASE_URL=postgresql://postgres:postgres@localhost:20301/athlete_manager

# Secret used to sign and verify session tokens. Must be long and random in production.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# How long password reset tokens are valid (hours).
PASSWORD_RESET_TOKEN_EXPIRY_HOURS=1

# Email of the initial SaaS Admin account created on first boot.
SAAS_ADMIN_EMAIL=admin@example.com

# Comma-separated list of origins the browser is allowed to call the API from.
CORS_ORIGINS=http://localhost:20305

# ── Frontend ──────────────────────────────────────────────────────────────────
# Base URL the browser uses to reach the backend API.
# In Docker Compose this defaults to localhost:20310 (the mapped backend port).
# Override for staging/production deployments.
VITE_API_URL=http://localhost:20310
